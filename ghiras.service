[Unit]
Description=Ghiras Club Backend API
After=network.target

[Service]
Type=notify
User=username
WorkingDirectory=/home/username/ghiras97/backend
Environment="PYTHONUNBUFFERED=1"
Environment="PATH=/home/username/ghiras97/backend/venv/bin"
ExecStart=/home/username/ghiras97/backend/venv/bin/uvicorn server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

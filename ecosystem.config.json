{
  "apps": [
    {
      "name": "ghiras-backend",
      "script": "uvicorn",
      "args": "server:app --host 0.0.0.0 --port 8000",
      "cwd": "/home/username/ghiras97/backend",
      "env": {
        "NODE_ENV": "production"
      },
      "instances": 1,
      "exec_mode": "fork",
      "restart_delay": 4000,
      "max_restarts": 10,
      "min_uptime": "10s",
      "autorestart": true,
      "watch": false,
      "ignore_watch": ["node_modules", "logs"]
    }
  ]
}
